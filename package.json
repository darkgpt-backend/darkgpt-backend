{
  "name": "darkgpt-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "DarkGPT online backend starter using Node.js, Express, and PostgreSQL.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "check": "node --check src/server.js",
    "hash:password": "node scripts/generate-password-hash.js",
    "users:template": "node scripts/generate-users-csv-template.js",
    "users:hash-csv": "node scripts/hash-users-from-csv.js",
    "users:csv-to-sql": "node scripts/csv-to-user-sql.js",
    "users:prepare-import": "npm run users:template && npm run users:hash-csv && npm run users:csv-to-sql"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
