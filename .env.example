PORT=5000
NODE_ENV=production
APP_BASE_URL=https://api.yourdomain.com
CORS_ORIGIN=https://your-android-api-gateway.example,https://your-frontend.example
TRUST_PROXY=true

DATABASE_URL=postgresql://postgres:password@localhost:5432/darkgpt

JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
DAILY_AI_MESSAGE_LIMIT=100
MONTHLY_AI_MESSAGE_LIMIT=1000

DEVICE_BINDING_ENABLED=false
PLAY_INTEGRITY_ENABLED=false
